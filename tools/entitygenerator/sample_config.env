# ============================================================================
# DMVCFramework Entity Generator - Configuration File
# ============================================================================
#
# Usage:
#   mvcentgen --config sample_config.env --output EntitiesU.pas
#
# Command-line overrides:
#   --connection <name>   Override CONNECTION_DEF
#   --output <file.pas>   Override OUTPUT_FILE
#

# --- Database Connection ---------------------------------------------------
#
# Option 1: Use a named FireDAC connection definition (from FDConnectionDefs.ini)
# CONNECTION_DEF=MyConnection
#
# Option 2: Specify connection parameters directly
DRIVER_ID=PG
SERVER=localhost
PORT=5432
DATABASE=mydb
USER_NAME=postgres
PASSWORD=secret

# Additional FireDAC parameters (prefix with FD_)
# FD_CharacterSet=UTF8
# FD_OsAuthent=No

# --- Schema ----------------------------------------------------------------
# Leave empty for default schema, or specify schema name
SCHEMA=public

# --- Output ----------------------------------------------------------------
# Output .pas file (can be overridden with --output)
OUTPUT_FILE=EntitiesU.pas

# --- Generation Options ----------------------------------------------------

# MVCNameCase attribute for generated classes
# Values: LowerCase, UpperCase, CamelCase, PascalCase, SnakeCase, AsIs
NAME_CASE=LowerCase

# Property name formatting
# Values: AsIs (keep database names), PascalCase (convert to PascalCase)
FIELD_NAME_FORMAT=PascalCase

# Generate ActiveRecordMappingRegistry.AddEntity() calls in initialization section
GENERATE_MAPPING=true

# Generate classes as abstract (TCustomXxx instead of TXxx)
CLASS_AS_ABSTRACT=false

# --- Table Filtering -------------------------------------------------------
#
# Each entry can be:
#   exact name    customers         (case insensitive)
#   wildcard      TBL_*             (* = any chars, ? = single char)
#   regex         /^(orders|items)$/  (enclosed in /.../)
#
# Examples:
#   TABLES=TBL_*,VW_*              only tables starting with TBL_ or VW_
#   TABLES=/^(customers|orders)$/  only "customers" and "orders" (regex)
#   EXCLUDE_TABLES=__*,tmp_*       skip tables starting with __ or tmp_
#   EXCLUDE_TABLES=/^sys/          skip tables starting with "sys" (regex)

# Comma-separated list of tables to generate (empty = all tables)
TABLES=

# Comma-separated list of tables to exclude
EXCLUDE_TABLES=
