# ============================================================================
# DMVCFramework Entity Generator - Configuration File
# ============================================================================
#
# Usage:
#   mvcentgen --config sample_config.env --output EntitiesU.pas
#
# Command-line overrides:
#   --connection <name>   Override CONNECTION_DEF
#   --output <file.pas>   Override OUTPUT_FILE
#

# --- Database Connection ---------------------------------------------------
#
# Option 1: Use a named FireDAC connection definition (from FDConnectionDefs.ini)
# CONNECTION_DEF=MyConnection
#
# Option 2: Specify connection parameters directly
DRIVER_ID=PG
SERVER=localhost
PORT=5432
DATABASE=mydb
USER_NAME=postgres
PASSWORD=secret

# Additional FireDAC parameters (prefix with FD_)
# FD_CharacterSet=UTF8
# FD_OsAuthent=No

# --- Schema ----------------------------------------------------------------
# Leave empty for default schema, or specify schema name
SCHEMA=public

# --- Output ----------------------------------------------------------------
# Output .pas file (can be overridden with --output)
OUTPUT_FILE=EntitiesU.pas

# --- Generation Options ----------------------------------------------------

# MVCNameCase attribute for generated classes
# Values: LowerCase, UpperCase, CamelCase, PascalCase, SnakeCase, AsIs
NAME_CASE=LowerCase

# Property name formatting
# Values: AsIs (keep database names), PascalCase (convert to PascalCase)
FIELD_NAME_FORMAT=PascalCase

# Generate ActiveRecordMappingRegistry.AddEntity() calls in initialization section
GENERATE_MAPPING=true

# Generate classes as abstract (TCustomXxx instead of TXxx)
CLASS_AS_ABSTRACT=false

# --- Table Filtering -------------------------------------------------------
#
# Each entry can be:
#   exact name    customers         (case insensitive)
#   wildcard      TBL_*             (* = any chars, ? = single char)
#   regex         /^(orders|items)$/  (enclosed in /.../)
#
# Examples:
#   TABLES=TBL_*,VW_*              only tables starting with TBL_ or VW_
#   TABLES=/^(customers|orders)$/  only "customers" and "orders" (regex)
#   EXCLUDE_TABLES=__*,tmp_*       skip tables starting with __ or tmp_
#   EXCLUDE_TABLES=/^sys/          skip tables starting with "sys" (regex)

# Comma-separated list of tables to generate (empty = all tables)
TABLES=

# Comma-separated list of tables to exclude
EXCLUDE_TABLES=

# --- Auto Validation Attributes (Tier 1) -----------------------------------
#
# Both flags are ON by default — the generator infers validation attributes
# from the database schema and emits them next to each [MVCTableField] line.
# To turn them off, either uncomment the lines below with =false, or pass
# --no-auto-required / --no-auto-maxlength on the command line.
#
# AUTO_REQUIRED  - Emits [MVCRequired] on every NOT NULL column except the
#                  primary key (when auto-generated, the framework supplies
#                  the value). Captures the "field is mandatory" rule that
#                  today the database raises only at INSERT time.
#
# AUTO_MAXLENGTH - Emits [MVCMaxLength(N)] on bounded VARCHAR / NVARCHAR
#                  columns. TEXT / CLOB / unbounded types are skipped.
#                  N is the column length reported by FireDAC metadata.
# AUTO_REQUIRED=false
# AUTO_MAXLENGTH=false

# READONLY_COLUMNS / REFRESH_COLUMNS — comma-separated lists of
# "table.column" pairs. They map directly onto the field options the
# generator emits next to [MVCTableField]:
#
#   READONLY_COLUMNS -> add foReadOnly to the field. Use for columns
#       the user must NOT write (computed / GENERATED ALWAYS / ROWVERSION /
#       audit-by-trigger). [MVCRequired] / [MVCMaxLength] are also
#       skipped on these fields — the user can't write them, validation
#       would never fire.
#
#   REFRESH_COLUMNS -> add foRefresh to the field. Use for columns
#       whose value should be re-fetched from the DB after INSERT /
#       UPDATE (e.g. a BEFORE trigger normalises the input).
#
# A column may appear in both lists; the resulting attribute will be
# [foReadOnly, foRefresh]. Match is case-insensitive.
#
# There is no auto-detection: FireDAC's metadata flags
# (caCalculated / caReadOnly) are inconsistently set across drivers —
# PostgreSQL in particular leaves them unset on GENERATED ALWAYS
# columns — so the generator relies on these explicit lists.
#
# Examples:
# READONLY_COLUMNS=customers.full_name,customers.row_ver,products.upper_sku
# REFRESH_COLUMNS=orders.normalised_email
READONLY_COLUMNS=
REFRESH_COLUMNS=

# --- Auto-Audit (Tier 2) ---------------------------------------------------
#
# When AUTO_AUDIT=true (the default), columns whose name matches one of the
# four canonical audit names get the matching [MVCAudit*] attribute and
# are excluded from [MVCRequired] (the framework populates them in
# OnBeforeInsert / OnBeforeUpdate, so the user never writes the value).
#
# Type validation: *At columns must be (Nullable)TDateTime, *By columns
# must be (Nullable)String. Mismatches are skipped with a warning.
#
# Override the names below if your schema follows a different convention
# (for example PG where snake_case is universal already, vs. shops that
# kept "RowCreatedDate" / "RowCreatedBy"). Disable the whole feature with
# `--no-auto-audit` on the command line or by setting AUTO_AUDIT=false.
# AUTO_AUDIT=false
# AUDIT_CREATED_AT_NAME=created_at
# AUDIT_UPDATED_AT_NAME=updated_at
# AUDIT_CREATED_BY_NAME=created_by
# AUDIT_UPDATED_BY_NAME=updated_by

# --- Auto-Soft-Delete (Tier 2) ---------------------------------------------
#
# When AUTO_SOFT_DELETE=true (the default), columns whose name matches one of
# the configured soft-delete names get [MVCSoftDeleted].
#
# Two storage modes, expressed via two separate CSV lists:
#   * SOFT_DELETE_TIMESTAMP_NAME -> column type must be NullableTDateTime
#     (plain TDateTime defaults to 1899-12-30 which never matches the
#     framework's `WHERE deleted_at IS NULL` auto-filter, so the column
#     MUST be NULL-able).
#   * SOFT_DELETE_FLAG_NAME -> column type must be Boolean.
#
# Defaults:
#   timestamp -> deleted_at
#   flag      -> is_deleted, deleted
#
# If a table has BOTH a timestamp-mode and a flag-mode column, the
# timestamp wins (more expressive — also captures *when* the row was
# soft-deleted) and a warning is logged.
#
# Mismatched types are skipped with a warning (e.g. `deleted_at INT`
# matches the name but the type is wrong - the generator does not emit
# [MVCSoftDeleted]).
#
# Disable the whole feature with `--no-auto-soft-delete` or AUTO_SOFT_DELETE=false.
# AUTO_SOFT_DELETE=false
# SOFT_DELETE_TIMESTAMP_NAME=deleted_at
# SOFT_DELETE_FLAG_NAME=is_deleted,deleted
