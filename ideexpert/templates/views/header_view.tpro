<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{:program_name}}</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">
  <link rel="stylesheet" href="/static/css/style.css">
  <script>
    (function() {
      var t = localStorage.getItem('dmvc-theme') || 'dark';
      document.documentElement.setAttribute('data-theme', t);
    })();
  </script>
</head>
<body>
  <nav>
    <div class="container">
      <ul>
        <li><strong>{{:program_name}}</strong></li>
      </ul>
      <ul>
        <li><a href="https://www.danieleteti.it/delphimvcframework/" target="_blank" rel="noopener">Docs</a></li>
        <li><button class="theme-toggle" id="themeToggle" title="Toggle theme">&#9790;</button></li>
      </ul>
    </div>
  </nav>
  <main class="container">
