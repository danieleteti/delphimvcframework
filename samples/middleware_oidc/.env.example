# Server
DMVC_SERVER_PORT=8080

# OIDC provider settings
OIDC_ISSUER=https://your-oidc-provider
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret

# Application base URL (used for OIDC redirect URI and end-session redirect)
# The OIDC redirect URI is derived as BASE_URL + /auth/callback
BASE_URL=http://localhost:8080

# Session JWT (used to sign the local session cookie)
JWT_SECRET=change-this-to-a-random-secret-at-least-32-characters
JWT_EXPIRATION_MINUTES=480

# View path (relative to executable)
DMVC_VIEW_PATH=templates
