        </BorlandProject>
    </ProjectExtensions>
    <Target Name="concurrency_speed_test_httpsys">
        <MSBuild Projects="concurrency_speed_test_httpsys.dproj"/>
    </Target>
    <Target Name="concurrency_speed_test_httpsys:Clean">
        <MSBuild Projects="concurrency_speed_test_httpsys.dproj" Targets="Clean"/>
    </Target>
    <Target Name="concurrency_speed_test_httpsys:Make">
        <MSBuild Projects="concurrency_speed_test_httpsys.dproj" Targets="Make"/>
