# Server
DMVC_SERVER_PORT=8080

# OIDC provider settings
OIDC_ISSUER=https://your-oidc-provider
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret

# Application base URL (used for OIDC redirect URI and end-session redirect)
# The OIDC redirect URI is derived as BASE_URL + /auth/callback
BASE_URL=http://localhost:8080

# Session JWT (used to sign the local session cookie - NOT the OIDC ID token)
JWT_SECRET=change-this-to-a-random-secret-at-least-32-characters
JWT_EXPIRATION_HOURS=8

# JWKS signature verification (optional)
# Set to "true" to verify ID token signatures against OIDC provider's public keys.
# Requires OpenSSL DLLs (libcrypto-3-x64.dll, libssl-3-x64.dll) in the app directory.
# When "false", the middleware trusts the ID token received over TLS from the provider.
OIDC_VERIFY_SIGNATURE=true

# View path (relative to executable)
DMVC_VIEW_PATH=templates
