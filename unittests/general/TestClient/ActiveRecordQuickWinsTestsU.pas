  [MVCTable('orders')]
  [MVCChangeTracking]
  TOrderCT = class(TMVCActiveRecord)
  strict private
    [MVCTableField('id', [foPrimaryKey, foAutoGenerated])]
    FID: Int64;
    [MVCTableField('total')]
    FTotal: Currency;
    [MVCTableField('notes')]
    FNotes: string;
    class var FExecutedSQLCount: Integer;
  protected
    // Spy hook: counts non-query SQL (INSERT / UPDATE / DELETE) executed
    // through this class. Tests use it to assert that UpdateIfChanged on
    // a clean row issues NO SQL. SELECTs go through OnBeforeExecuteQuerySQL,
    // which we don't override - so GetByPK does NOT bump the counter.
    procedure OnBeforeExecuteSQL(var SQL: string); override;
  public
    property ID: Int64 read FID write FID;
    property Total: Currency read FTotal write FTotal;
    property Notes: string read FNotes write FNotes;
    class property ExecutedSQLCount: Integer
      read FExecutedSQLCount write FExecutedSQLCount;
  end;

  [MVCTable('customers_sd')]
  TCustomerSDTimestamp = class(TMVCActiveRecord)
  strict private
    [MVCTableField('id', [foPrimaryKey, foAutoGenerated])]
