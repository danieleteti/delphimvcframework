implementation

procedure TOrderCT.OnBeforeExecuteSQL(var SQL: string);
begin
  inherited;
  Inc(FExecutedSQLCount);
end;

procedure TTestChangeTracking.SetUp;
begin
  FConn := TFDConnection.Create(nil);
  FConn.DriverName := 'SQLite';
  FConn.Params.Values['Database'] := ':memory:';
  FConn.Connected := True;
  FConn.ExecSQL(
    'CREATE TABLE orders (id INTEGER PRIMARY KEY AUTOINCREMENT, ' +
    'total NUMERIC, notes TEXT)');
  FConn.ExecSQL(
    'CREATE TABLE orders_notrack (id INTEGER PRIMARY KEY AUTOINCREMENT, ' +
    'total NUMERIC)');
  ActiveRecordConnectionsRegistry.AddDefaultConnection(FConn);
end;

procedure TTestChangeTracking.TearDown;
begin
  ActiveRecordConnectionsRegistry.RemoveDefaultConnection;
  FConn.Free;
end;

procedure TTestChangeTracking.SeedRow(out AID: Int64);
var
  lOrder: TOrderCT;
begin
  lOrder := TOrderCT.Create;
  try
    lOrder.Total := 100.0;
    lOrder.Notes := 'initial';
    lOrder.Insert;
    AID := lOrder.ID;
  finally
    lOrder.Free;
  end;
end;

procedure TTestChangeTracking.TestNotChangedAfterLoad;
var
  lID: Int64;
  lOrder: TOrderCT;
begin
  SeedRow(lID);
  lOrder := TMVCActiveRecord.GetByPK<TOrderCT>(lID);
  try
    Assert.IsFalse(lOrder.IsChanged, 'Just-loaded record must not be flagged as changed');
    Assert.AreEqual<NativeInt>(0, Length(lOrder.GetChangedFields), 'No fields should be flagged as changed');
  finally
    lOrder.Free;
  end;
end;

procedure TTestChangeTracking.TestChangedAfterFieldChange;
var
  lID: Int64;
  lOrder: TOrderCT;
begin
  SeedRow(lID);
  lOrder := TMVCActiveRecord.GetByPK<TOrderCT>(lID);
  try
    lOrder.Total := 200.0;
    Assert.IsTrue(lOrder.IsChanged, 'After change, IsChanged must be True');
    Assert.IsTrue(lOrder.IsChanged('total'), 'Total must be flagged as changed');
    Assert.IsFalse(lOrder.IsChanged('notes'), 'Notes was not modified; must not be flagged');
  finally
    lOrder.Free;
  end;
end;

procedure TTestChangeTracking.TestNotChangedAfterUpdate;
var
  lID: Int64;
  lOrder: TOrderCT;
begin
  SeedRow(lID);
  lOrder := TMVCActiveRecord.GetByPK<TOrderCT>(lID);
  try
    lOrder.Total := 200.0;
    lOrder.Update;
    Assert.IsFalse(lOrder.IsChanged,
      'After successful Update, snapshot must be rehashed - no longer flagged');
  finally
    lOrder.Free;
  end;
end;

procedure TTestChangeTracking.TestGetChangedFieldsByName;
var
  lID: Int64;
  lOrder: TOrderCT;
  lChanged: TArray<string>;
begin
  SeedRow(lID);
  lOrder := TMVCActiveRecord.GetByPK<TOrderCT>(lID);
  try
    lOrder.Total := 200.0;
    lOrder.Notes := 'changed';
    lChanged := lOrder.GetChangedFields;
    Assert.AreEqual<NativeInt>(2, Length(lChanged), 'Both fields must be flagged');
    // Order is map-iteration dependent; assert membership not order
    Assert.IsTrue(
      ((lChanged[0] = 'total') and (lChanged[1] = 'notes')) or
      ((lChanged[0] = 'notes') and (lChanged[1] = 'total')),
      'Both total and notes must appear in the changed list');
  finally
    lOrder.Free;
  end;
end;

procedure TTestChangeTracking.TestIsChangedByFieldName;
var
  lID: Int64;
  lOrder: TOrderCT;
begin
  SeedRow(lID);
  lOrder := TMVCActiveRecord.GetByPK<TOrderCT>(lID);
  try
    lOrder.Notes := 'changed only';
    Assert.IsTrue(lOrder.IsChanged('notes'), 'notes must be flagged');
    Assert.IsFalse(lOrder.IsChanged('total'), 'total must not be flagged');
    Assert.IsFalse(lOrder.IsChanged('nonexistent_field'),
      'Non-existent field returns False, not exception');
    // FieldName lookup is case-insensitive (uses SameText).
    Assert.IsTrue(lOrder.IsChanged('NOTES'), 'lookup must be case-insensitive');
    Assert.IsTrue(lOrder.IsChanged('Notes'), 'lookup must be case-insensitive');
  finally
    lOrder.Free;
  end;
end;

procedure TTestChangeTracking.TestUpdateEmitsOnlyChangedColumns;
var
  lID: Int64;
  lOrder: TOrderCT;
begin
  SeedRow(lID);
  lOrder := TMVCActiveRecord.GetByPK<TOrderCT>(lID);
  try
    lOrder.Notes := 'changed only';
    lOrder.Update;
  finally
    lOrder.Free;
  end;
  // Verify total is unchanged and notes is updated
  lOrder := TMVCActiveRecord.GetByPK<TOrderCT>(lID);
  try
    Assert.AreEqual(Currency(100), lOrder.Total, 'Total must NOT have been touched');
    Assert.AreEqual('changed only', lOrder.Notes, 'Notes must have been written');
  finally
    lOrder.Free;
  end;
end;

procedure TTestChangeTracking.TestUpdateIfChangedSkipsWhenClean;
var
  lID: Int64;
  lOrder: TOrderCT;
begin
  SeedRow(lID);
  lOrder := TMVCActiveRecord.GetByPK<TOrderCT>(lID);
  try
    // Reset the spy AFTER GetByPK so we only measure what UpdateIfChanged
    // does next. The spy counts INSERT / UPDATE / DELETE; SELECTs are not
    // counted (they go through OnBeforeExecuteQuerySQL).
    TOrderCT.ExecutedSQLCount := 0;
    lOrder.UpdateIfChanged;  // should early-return — nothing changed
    Assert.AreEqual<Integer>(0, TOrderCT.ExecutedSQLCount,
      'UpdateIfChanged on a clean row must NOT issue any SQL');
    Assert.IsFalse(lOrder.IsChanged, 'Record must remain clean after UpdateIfChanged no-op');
  finally
    lOrder.Free;
  end;
end;

procedure TTestChangeTracking.TestUpdateIfChangedExecutesWhenChanged;
var
  lID: Int64;
  lOrder: TOrderCT;
begin
  SeedRow(lID);
  lOrder := TMVCActiveRecord.GetByPK<TOrderCT>(lID);
  try
    TOrderCT.ExecutedSQLCount := 0;
    lOrder.Notes := 'changed';
    lOrder.UpdateIfChanged;
    Assert.AreEqual<Integer>(1, TOrderCT.ExecutedSQLCount,
      'UpdateIfChanged must issue exactly one UPDATE when there are changes');
    Assert.IsFalse(lOrder.IsChanged, 'After UpdateIfChanged the snapshot must be rebuilt');
  finally
    lOrder.Free;
  end;
  lOrder := TMVCActiveRecord.GetByPK<TOrderCT>(lID);
  try
    Assert.AreEqual('changed', lOrder.Notes, 'Persisted value must reflect the change');
  finally
    lOrder.Free;
  end;
end;

procedure TTestChangeTracking.TestUpdateIfChangedRaisesOnNonTrackedClass;
begin
  Assert.WillRaise(
    procedure
    var
      lO: TOrderNoTrack;
    begin
      lO := TOrderNoTrack.Create;
      try
        lO.UpdateIfChanged;
      finally
        lO.Free;
      end;
    end,
    EMVCActiveRecord);
end;

{ TTestSoftDelete }

procedure TTestSoftDelete.SetUp;
begin
  FConn := TFDConnection.Create(nil);
  FConn.DriverName := 'SQLite';
  FConn.Params.Values['Database'] := ':memory:';
  FConn.Connected := True;
  FConn.ExecSQL(
    'CREATE TABLE customers_sd (id INTEGER PRIMARY KEY AUTOINCREMENT, ' +
    'name TEXT, deleted_at TEXT)');
  FConn.ExecSQL(
    'CREATE TABLE orders_sd (id INTEGER PRIMARY KEY AUTOINCREMENT, ' +
    'description TEXT, is_deleted INTEGER DEFAULT 0)');
  ActiveRecordConnectionsRegistry.AddDefaultConnection(FConn);
end;

procedure TTestSoftDelete.TearDown;
begin
  ActiveRecordConnectionsRegistry.RemoveDefaultConnection;
  FConn.Free;
end;

procedure TTestSoftDelete.TestSoftDeleteTimestampSetsField;
var
  lC: TCustomerSDTimestamp;
  lQry: TFDQuery;
  lDeletedAtAfter: string;
begin
  lC := TCustomerSDTimestamp.Create;
  try
    lC.Name := 'Alice';
    lC.Insert;
    lC.Delete;
  finally
    lC.Free;
  end;
  lQry := TFDQuery.Create(nil);
  try
    lQry.Connection := FConn;
    lQry.SQL.Text := 'SELECT deleted_at FROM customers_sd WHERE name = :n';
    lQry.ParamByName('n').AsString := 'Alice';
    lQry.Open;
    lDeletedAtAfter := lQry.FieldByName('deleted_at').AsString;
    Assert.IsFalse(lDeletedAtAfter.IsEmpty, 'deleted_at must be populated after soft-delete');
  finally
    lQry.Free;
  end;
end;

procedure TTestSoftDelete.TestSoftDeleteFlagSetsField;
var
  lO: TOrderSDFlag;
  lQry: TFDQuery;
begin
  lO := TOrderSDFlag.Create;
  try
    lO.Description := 'Test';
    lO.Insert;
    lO.Delete;
  finally
    lO.Free;
  end;
  lQry := TFDQuery.Create(nil);
  try
    lQry.Connection := FConn;
    lQry.SQL.Text := 'SELECT is_deleted FROM orders_sd WHERE description = :d';
    lQry.ParamByName('d').AsString := 'Test';
    lQry.Open;
    Assert.IsTrue(lQry.FieldByName('is_deleted').AsInteger <> 0,
      'is_deleted must be non-zero (true) after soft-delete');
  finally
    lQry.Free;
  end;
end;

procedure TTestSoftDelete.TestSelectAutoFiltersDeleted;
var
  lC: TCustomerSDTimestamp;
  lList: TObjectList<TCustomerSDTimestamp>;
begin
  lC := TCustomerSDTimestamp.Create;
  try
    lC.Name := 'Alive';
    lC.Insert;
  finally
    lC.Free;
  end;
  lC := TCustomerSDTimestamp.Create;
  try
    lC.Name := 'Deleted';
    lC.Insert;
    lC.Delete;
  finally
    lC.Free;
  end;
  lList := TMVCActiveRecord.All<TCustomerSDTimestamp>;
  try
    Assert.AreEqual<NativeInt>(1, lList.Count, 'Default scope must filter out soft-deleted rows');
    Assert.AreEqual('Alive', lList[0].Name);
  finally
    lList.Free;
  end;
end;

procedure TTestSoftDelete.TestIncludeSoftDeletedScopeReturnsAll;
var
  lC: TCustomerSDTimestamp;
  lList: TObjectList<TCustomerSDTimestamp>;
begin
  lC := TCustomerSDTimestamp.Create;
  try
    lC.Name := 'Alive2';
    lC.Insert;
  finally
    lC.Free;
  end;
  lC := TCustomerSDTimestamp.Create;
  try
    lC.Name := 'Deleted2';
    lC.Insert;
    lC.Delete;
  finally
    lC.Free;
  end;
  TMVCActiveRecord.IncludeSoftDeleted(True);
  try
    lList := TMVCActiveRecord.All<TCustomerSDTimestamp>;
    try
      Assert.AreEqual<NativeInt>(2, lList.Count,
        'IncludeSoftDeleted scope must return all rows including deleted');
    finally
      lList.Free;
    end;
  finally
    TMVCActiveRecord.IncludeSoftDeleted(False);
  end;
end;

procedure TTestSoftDelete.TestIsDeletedTimestamp;
var
  lC: TCustomerSDTimestamp;
begin
  lC := TCustomerSDTimestamp.Create;
  try
    lC.Name := 'TestIsDeleted';
    lC.Insert;
    Assert.IsFalse(lC.IsDeleted, 'Just-inserted record must not be deleted');
    lC.Delete;
    Assert.IsTrue(lC.IsDeleted, 'After Delete: IsDeleted must be True');
  finally
    lC.Free;
  end;
end;

procedure TTestSoftDelete.TestIsDeletedFlag;
var
  lO: TOrderSDFlag;
begin
  lO := TOrderSDFlag.Create;
  try
    lO.Description := 'FlagTest';
    lO.Insert;
    Assert.IsFalse(lO.IsDeleted, 'Just-inserted record must not be deleted');
    lO.Delete;
    Assert.IsTrue(lO.IsDeleted, 'After Delete: IsDeleted must be True');
  finally
    lO.Free;
  end;
end;

procedure TTestSoftDelete.TestRestore;
var
  lC: TCustomerSDTimestamp;
  lID: Int64;
  lReloaded: TCustomerSDTimestamp;
begin
  lC := TCustomerSDTimestamp.Create;
  try
    lC.Name := 'ToRestore';
    lC.Insert;
    lID := lC.ID;
    lC.Delete;
    Assert.IsTrue(lC.IsDeleted, 'After Delete: must be deleted');
    lC.Restore;
    Assert.IsFalse(lC.IsDeleted, 'After Restore: must not be deleted');
  finally
    lC.Free;
  end;
  // Reload and confirm the row is visible in normal scope
  lReloaded := TMVCActiveRecord.GetByPK<TCustomerSDTimestamp>(lID);
  try
    Assert.IsFalse(lReloaded.IsDeleted, 'Reload: row must be visible after Restore');
  finally
    lReloaded.Free;
  end;
end;

procedure TTestSoftDelete.TestRestoreOnNonSoftRaises;
begin
  Assert.WillRaise(
    procedure
    var
      lO: TOrderCT;
    begin
      lO := TOrderCT.Create;
      try
        lO.Restore;
      finally
        lO.Free;
      end;
    end,
    EMVCActiveRecord);
end;

procedure TTestSoftDelete.TestRestoreOnAliveRaises;
var
  lC: TCustomerSDTimestamp;
begin
  lC := TCustomerSDTimestamp.Create;
  try
    lC.Name := 'NeverDeleted';
    lC.Insert;
    Assert.WillRaise(
      procedure
      begin
        lC.Restore;
      end,
      EMVCActiveRecord,
      'Restore on a live record must raise EMVCActiveRecord');
  finally
    lC.Free;
  end;
end;

procedure TTestSoftDelete.TestHardDeleteBypassesSoftDelete;
var
  lC: TCustomerSDTimestamp;
  lID: Int64;
  lQry: TFDQuery;
begin
  lC := TCustomerSDTimestamp.Create;
  try
    lC.Name := 'HardDel';
    lC.Insert;
    lID := lC.ID;
    lC.HardDelete;
  finally
    lC.Free;
  end;
  lQry := TFDQuery.Create(nil);
  try
    lQry.Connection := FConn;
    lQry.SQL.Text := 'SELECT COUNT(*) AS n FROM customers_sd WHERE id = :id';
    lQry.ParamByName('id').AsLargeInt := lID;
    lQry.Open;
    Assert.AreEqual(0, lQry.FieldByName('n').AsInteger,
      'HardDelete must remove the row physically');
  finally
    lQry.Free;
  end;
end;

procedure TTestSoftDelete.TestHardDeleteRQLBulk;
var
  lC: TCustomerSDTimestamp;
  lIDSoft: Int64;
  lIDHard: Int64;
  lQry: TFDQuery;
begin
  // Insert two rows; soft-delete one of them first
  lC := TCustomerSDTimestamp.Create;
  try
    lC.Name := 'BulkHardA';
    lC.Insert;
    lIDSoft := lC.ID;
    lC.Delete; // soft-delete
  finally
    lC.Free;
  end;
  lC := TCustomerSDTimestamp.Create;
  try
    lC.Name := 'BulkHardB';
    lC.Insert;
    lIDHard := lC.ID;
  finally
    lC.Free;
  end;
  // Hard-delete both via bulk RQL (match both names)
  TMVCActiveRecord.HardDeleteRQL<TCustomerSDTimestamp>(
    'in(Name,["BulkHardA","BulkHardB"])');
  lQry := TFDQuery.Create(nil);
  try
    lQry.Connection := FConn;
    lQry.SQL.Text :=
      'SELECT COUNT(*) AS n FROM customers_sd WHERE id IN (:id1, :id2)';
    lQry.ParamByName('id1').AsLargeInt := lIDSoft;
    lQry.ParamByName('id2').AsLargeInt := lIDHard;
    lQry.Open;
    Assert.AreEqual(0, lQry.FieldByName('n').AsInteger,
      'HardDeleteRQL must physically remove all matching rows');
  finally
    lQry.Free;
  end;
end;

procedure TTestSoftDelete.TestRestoreRQLBulk;
var
  lC: TCustomerSDTimestamp;
  lID1: Int64;
  lID2: Int64;
  lList: TObjectList<TCustomerSDTimestamp>;
begin
  lC := TCustomerSDTimestamp.Create;
  try
    lC.Name := 'BulkRestoreA';
    lC.Insert;
    lID1 := lC.ID;
    lC.Delete;
  finally
    lC.Free;
  end;
  lC := TCustomerSDTimestamp.Create;
  try
    lC.Name := 'BulkRestoreB';
    lC.Insert;
    lID2 := lC.ID;
    lC.Delete;
  finally
    lC.Free;
  end;
  // Both are soft-deleted; restore them via bulk RQL
  TMVCActiveRecord.RestoreRQL<TCustomerSDTimestamp>(
    'in(Name,["BulkRestoreA","BulkRestoreB"])');
  // Now they should be visible in normal scope
  lList := TMVCActiveRecord.Where<TCustomerSDTimestamp>(
    'id IN (:id1, :id2)', [lID1, lID2]);
  try
    Assert.AreEqual<NativeInt>(2, lList.Count,
      'RestoreRQL must make both rows visible in normal scope');
  finally
    lList.Free;
  end;
end;

procedure TTestSoftDelete.TestDeleteRQLDispatchesSoftDelete;
var
  lC: TCustomerSDTimestamp;
  lID: Int64;
  lQry: TFDQuery;
begin
  lC := TCustomerSDTimestamp.Create;
  try
    lC.Name := 'RQLDispatch';
    lC.Insert;
    lID := lC.ID;
  finally
    lC.Free;
  end;
  // DeleteRQL on a soft-delete class must do a soft-delete (UPDATE), not a physical DELETE
  TMVCActiveRecord.DeleteRQL<TCustomerSDTimestamp>('eq(Name,"RQLDispatch")');
  // Row must still exist physically
  lQry := TFDQuery.Create(nil);
  try
    lQry.Connection := FConn;
    lQry.SQL.Text := 'SELECT COUNT(*) AS n FROM customers_sd WHERE id = :id';
    lQry.ParamByName('id').AsLargeInt := lID;
    lQry.Open;
    Assert.AreEqual(1, lQry.FieldByName('n').AsInteger,
      'DeleteRQL on a soft-delete class must keep the row (UPDATE not DELETE)');
    // And the sentinel must be set
    lQry.Close;
    lQry.SQL.Text :=
      'SELECT deleted_at FROM customers_sd WHERE id = :id';
    lQry.ParamByName('id').AsLargeInt := lID;
    lQry.Open;
    Assert.IsFalse(lQry.FieldByName('deleted_at').IsNull,
      'deleted_at must be populated after DeleteRQL soft-delete dispatch');
  finally
    lQry.Free;
  end;
end;

