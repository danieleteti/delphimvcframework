{ TTestIsNew }

procedure TTestIsNew.SetUp;
begin
  FConn := TFDConnection.Create(nil);
  FConn.DriverName := 'SQLite';
  FConn.Params.Values['Database'] := ':memory:';
  FConn.Connected := True;
  FConn.ExecSQL(
    'CREATE TABLE isnew_nullable (id INTEGER PRIMARY KEY AUTOINCREMENT, name TEXT)');
  FConn.ExecSQL(
    'CREATE TABLE isnew_plain (id INTEGER PRIMARY KEY AUTOINCREMENT, name TEXT)');
  ActiveRecordConnectionsRegistry.AddDefaultConnection(FConn);
end;

procedure TTestIsNew.TearDown;
begin
  ActiveRecordConnectionsRegistry.RemoveDefaultConnection;
  FConn.Free;
end;

procedure TTestIsNew.TestFreshInstanceWithNullablePKIsNew;
var
  lE: TIsNewNullablePK;
begin
  lE := TIsNewNullablePK.Create;
  try
    Assert.IsTrue(lE.IsNew, 'A just-constructed entity must be IsNew');
    Assert.IsFalse(lE.IsPersisted);
  finally
    lE.Free;
  end;
end;

procedure TTestIsNew.TestFreshInstanceWithPlainPKIsNew;
var
  lE: TIsNewPlainPK;
begin
  lE := TIsNewPlainPK.Create;
  try
    // Plain Int64 default-constructs to 0 -> TValue.IsEmpty is True -> IsNew.
    Assert.IsTrue(lE.IsNew, 'Plain PK = 0 must be reported as new');
    Assert.IsFalse(lE.IsPersisted);
  finally
    lE.Free;
  end;
end;

procedure TTestIsNew.TestAfterInsertNotNew;
var
  lE: TIsNewNullablePK;
begin
  lE := TIsNewNullablePK.Create;
  try
    lE.Name := 'Alice';
    Assert.IsTrue(lE.IsNew, 'Sanity check: new before Insert');
    lE.Insert;
    Assert.IsFalse(lE.IsNew,
      'After Insert the auto-generated PK must be assigned -> not new anymore');
    Assert.IsTrue(lE.IsPersisted);
  finally
    lE.Free;
  end;
end;

procedure TTestIsNew.TestAfterLoadNotNew;
var
  lInsertedID: Int64;
  lInserted: TIsNewNullablePK;
  lLoaded: TIsNewNullablePK;
begin
  lInserted := TIsNewNullablePK.Create;
  try
    lInserted.Name := 'Bob';
    lInserted.Insert;
    lInsertedID := lInserted.ID.Value;
  finally
    lInserted.Free;
  end;

  lLoaded := TMVCActiveRecord.GetByPK<TIsNewNullablePK>(lInsertedID);
  try
    Assert.IsFalse(lLoaded.IsNew,
      'A row freshly loaded from the database must report IsPersisted');
    Assert.IsTrue(lLoaded.IsPersisted);
  finally
    lLoaded.Free;
  end;
end;

procedure TTestIsNew.TestIsPersistedIsNegationOfIsNew;
var
  lE: TIsNewNullablePK;
begin
  // Hard-lock the invariant so future refactors cannot let the two methods
  // drift apart silently.
  lE := TIsNewNullablePK.Create;
  try
    Assert.AreEqual(not lE.IsNew, lE.IsPersisted);
    lE.Name := 'Carol';
    lE.Insert;
    Assert.AreEqual(not lE.IsNew, lE.IsPersisted);
  finally
    lE.Free;
  end;
end;

{ TTestForefresh }

procedure TTestForefresh.SetUp;
begin
  FConn := TFDConnection.Create(nil);
  FConn.DriverName := 'SQLite';
  FConn.Params.Values['Database'] := ':memory:';
  FConn.Connected := True;
  // refreshable: 'name' is user-controlled. 'upper_name' is a computed
  // column (UPPER(name)) — the canonical case foRefresh covers, where
  // RETURNING / OUTPUT must surface the DB-computed value back into the
  // in-memory instance without an extra round-trip.
  // The 'notes' column is foRefresh too but is plain - used to verify
  // that foRefresh on a regular writable column simply round-trips.
  //
  // Computed columns on SQLite require 3.31+ (Jan 2020). The bundled
  // FireDAC SQLite engine on supported Delphi versions includes it.
  FConn.ExecSQL(
    'CREATE TABLE refreshable (' +
    '  id INTEGER PRIMARY KEY AUTOINCREMENT, ' +
    '  name TEXT, ' +
    '  upper_name TEXT GENERATED ALWAYS AS (UPPER(name)) STORED, ' +
    '  notes TEXT)');
  ActiveRecordConnectionsRegistry.AddDefaultConnection(FConn);
end;

procedure TTestForefresh.TearDown;
begin
  ActiveRecordConnectionsRegistry.RemoveDefaultConnection;
  FConn.Free;
end;

procedure TTestForefresh.TestInsertRefetchesTriggerOutput;
var
  lR: TRefreshable;
begin
  lR := TRefreshable.Create;
  try
    lR.Name := 'alice';
    Assert.IsFalse(lR.UpperName.HasValue,
      'UpperName must be NULL before Insert');
    lR.Insert;
    Assert.IsTrue(lR.UpperName.HasValue,
      'foRefresh must surface the trigger-written value');
    Assert.AreEqual('ALICE', lR.UpperName.Value,
      'Trigger must have uppercased the inserted name');
  finally
    lR.Free;
  end;
end;

procedure TTestForefresh.TestUpdateRefetchesTriggerOutput;
var
  lID: Int64;
  lR: TRefreshable;
begin
  lR := TRefreshable.Create;
  try
    lR.Name := 'alice';
    lR.Insert;
    lID := lR.ID;
  finally
    lR.Free;
  end;

  lR := TMVCActiveRecord.GetByPK<TRefreshable>(lID);
  try
    Assert.AreEqual('ALICE', lR.UpperName.Value,
      'Sanity check: state captured by the AFTER INSERT trigger');
    lR.Name := 'bob';
    lR.Update;
    Assert.AreEqual('BOB', lR.UpperName.Value,
      'foRefresh must refetch the trigger-rewritten value after Update');
  finally
    lR.Free;
  end;
end;

procedure TTestForefresh.TestForefreshFieldStaysWritable;
var
  lR: TRefreshable;
  lLoaded: TRefreshable;
  lID: Int64;
begin
  // foRefresh does NOT make a column read-only. If the caller writes it,
  // the value is persisted; the post-write SELECT just re-reads what's
  // there. For a column that no trigger touches, that means a clean
  // round-trip.
  lR := TRefreshable.Create;
  try
    lR.Name := 'bob';
    lR.Notes := 'user-written notes';
    lR.Insert;
    lID := lR.ID;
    Assert.IsTrue(lR.Notes.HasValue);
    Assert.AreEqual('user-written notes', lR.Notes.Value,
      'foRefresh must not blow away values the caller assigned');
  finally
    lR.Free;
  end;

  // Confirm by reloading from a fresh instance.
  lLoaded := TMVCActiveRecord.GetByPK<TRefreshable>(lID);
  try
    Assert.AreEqual('user-written notes', lLoaded.Notes.Value);
  finally
    lLoaded.Free;
  end;
end;

procedure TTestForefresh.TestPKAndForefreshBothFilled;
var
  lR: TRefreshable;
begin
  // Sanity: a single Insert must populate both the auto-generated PK and
  // every foRefresh field — the framework's RETURNING fetches the PK,
  // RefreshFromDB fetches the foRefresh columns.
  lR := TRefreshable.Create;
  try
    lR.Name := 'combined';
    lR.Notes := 'plain notes';
    lR.Insert;
    Assert.IsTrue(lR.ID > 0,             'PK must be filled');
    Assert.IsTrue(lR.UpperName.HasValue, 'UpperName must be filled by trigger');
    Assert.AreEqual('COMBINED', lR.UpperName.Value);
    Assert.AreEqual('plain notes', lR.Notes.Value);
  finally
    lR.Free;
  end;
end;

