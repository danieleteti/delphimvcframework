    property Name: string read FName write FName;
    property DeletedAt: NullableTDateTime read FDeletedAt write FDeletedAt;
  end;

  // ---------------------------------------------------------------
  // foRefresh — entities used by TTestForefresh.
  //
  // foRefresh declares "after Insert/Update, re-SELECT this column from
  // the DB so any server-side transformation (trigger, computed column,
  // identity-style adjustment) is reflected back into the in-memory
  // instance". The field stays fully writable.
  //
  // TRefreshable models the canonical use case: a trigger writes a
  // derived value into `upper_name` whenever `name` is changed.
  //   * `name`        - user-controlled, written verbatim
  //   * `upper_name`  - foRefresh, populated by the trigger to UPPER(name)
  //   * `notes`       - foRefresh, written verbatim by the user — proves
  //                     that foRefresh on an untransformed column simply
  //                     round-trips (no spurious NULL-ing).
  // ---------------------------------------------------------------
  [MVCTable('refreshable')]
  TRefreshable = class(TMVCActiveRecord)
  strict private
    [MVCTableField('id', [foPrimaryKey, foAutoGenerated])]
    FID: Int64;
    [MVCTableField('name')]
    FName: string;
    // Computed column — read-only for the framework, refreshed via
    // RETURNING after every INSERT / UPDATE so the in-memory instance
    // mirrors the DB-computed value.
    [MVCTableField('upper_name', [foReadOnly, foRefresh])]
    FUpperName: NullableString;
    // Plain writable column also marked foRefresh - exercises the
    // "writable + refetch" combination (no transformation, just a
    // round-trip via RETURNING).
    [MVCTableField('notes', [foRefresh])]
    FNotes: NullableString;
  public
    property ID: Int64 read FID write FID;
    property Name: string read FName write FName;
    property UpperName: NullableString read FUpperName write FUpperName;
    property Notes: NullableString read FNotes write FNotes;
  end;

